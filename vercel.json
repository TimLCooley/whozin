{
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/process-invites",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/process-reminders",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/health-check",
      "schedule": "0 8 * * *"
    }
  ]
}
